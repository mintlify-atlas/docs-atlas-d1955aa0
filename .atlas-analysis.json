  "keyFeatures": [
    "BDD-driven test scenarios written in plain English Gherkin syntax",
    "Rest Assured HTTP client for API request/response validation",
    "Cucumber Scenario Outline for data-driven testing",
    "Automatic request/response logging to file",
    "Rich HTML test reports via Maven Cucumber Reporting plugin",
    "Reusable RequestSpecification with singleton pattern",
    "Hooks for independent scenario execution (Delete runs without Add)",
    "Jackson Databind POJO serialization for request body construction"
  ],
  "publicApiSurface": [
    "POST /maps/api/place/add/json — Add a new place",
    "GET /maps/api/place/get/json — Retrieve a place by place_id",
    "POST /maps/api/place/delete/json — Delete a place by place_id",
    "APIResources enum: addPlaceAPI, getPlaceAPI, deletePlaceAPI",
    "Utils.requestSpecification() — Shared base request spec",
    "Utils.getJsonPath(Response, String) — Extract JSON fields from responses",
    "TestDataBuild.addPlacePayload(name, language, address) — Build Add Place request body",
    "TestDataBuild.deletePlacePayload(place_id) — Build Delete Place request body",
    "Cucumber tags: @AddPlace, @DeletePlace, @Regression"
  ]
}
